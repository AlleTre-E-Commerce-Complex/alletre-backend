generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id                       Int                  @id @default(autoincrement())
  userName                 String?
  email                    String?              @unique
  password                 String?
  phone                    String?              @unique
  createdAt                DateTime             @default(now())
  imageLink                String?
  imagePath                String?
  isOAuth                  Boolean              @default(false)
  hasCompletedProfile      Boolean              @default(false)
  isVerified               Boolean              @default(false)





  oAuthType                OAuthType?
  lang                     String               @default("en")
  socketId                 String?
  stripeId                 String?
  stripeConnectedAccountId String?
  ipAddress                String?
  isBlocked                Boolean              @default(false)
  alletreWallet            AlletreWallet[]
  auctions                 Auction[]
  auctionComplaints        AuctionComplaints[]
  bankAccount              BankAccount[]
  bids                     Bids[]
  bugReports               BugReport[]
  bugReportMessages        BugReportMessage[]
  chatMessages             ChatMessage[]
  buyerConversations       Conversation[]       @relation("BuyerConversations")
  sellerConversations      Conversation[]       @relation("SellerConversations")
  JoinedAuction            JoinedAuction[]
  listedProducts           ListedProducts[]
  locations                Location[]
  notifications            Notification[]
  Payment                  Payment[]
  ListedProducts           Product[]
  profit                   Profit[]
  pushSubscriptions        PushSubscription?
  wallet                   Wallet[]
  watchLists               WatchList[]
  withdrawalRequests       WithdrawalRequests[]
  comments                 Comment[]
  commentLikes             CommentLike[]
}

model NonRegisteredUser {
  id          Int       @id @default(autoincrement())
  name        String?
  mobile      String?
  email       String?
  address     String?
  companyName String?
  remarks     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  categoryId  Int?
  category    Category? @relation(fields: [categoryId], references: [id])
}

model SubscribedUser {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
  isActive  Boolean
}

model UnsubscribedUser {
  id        Int      @id @default(autoincrement())
  phone     String   @unique
  reason    String?
  createdAt DateTime @default(now())
  email     String?
}

model Country {
  id        Int        @id @default(autoincrement())
  nameAr    String
  nameEn    String
  createdAt DateTime   @default(now())
  currency  String?
  cities    City[]
  locations Location[]
  Product   Product[]
}

model BankAccount {
  id                 Int                  @id @default(autoincrement())
  accountHolderName  String
  bankName           String
  accountNumber      String
  routingNumber      String
  userId             Int
  user               User                 @relation(fields: [userId], references: [id])
  withdrawalRequests WithdrawalRequests[]
}

model WithdrawalRequests {
  id               Int              @id @default(autoincrement())
  amount           Decimal
  referenceNumber  Int              @unique @default(autoincrement())
  bankAccountId    Int
  userId           Int
  withdrawalStatus WithdrawalStatus @default(PENDING)
  bankAccount      BankAccount      @relation(fields: [bankAccountId], references: [id])
  user             User             @relation(fields: [userId], references: [id])
}

model City {
  id        Int        @id @default(autoincrement())
  nameAr    String
  nameEn    String
  createdAt DateTime   @default(now())
  countryId Int
  country   Country    @relation(fields: [countryId], references: [id])
  locations Location[]
  Product   Product[]
}

model Location {
  id             Int              @id @default(autoincrement())
  userId         Int
  createdAt      DateTime         @default(now())
  address        String
  zipCode        String?
  addressLabel   String?
  isMain         Boolean          @default(false)
  phone          String?
  lat            Float?
  lng            Float?
  cityId         Int
  countryId      Int
  auctions       Auction[]
  listedProducts ListedProducts[]
  city           City             @relation(fields: [cityId], references: [id])
  country        Country          @relation(fields: [countryId], references: [id])
  user           User             @relation(fields: [userId], references: [id])
}

model Category {
  id                              Int                 @id @default(autoincrement())
  createdAt                       DateTime            @default(now())
  nameAr                          String
  nameEn                          String
  hasUsageCondition               Boolean             @default(false)
  bidderDepositFixedAmount        Decimal?
  sellerDepositFixedAmount        Decimal?
  bannerLink                      String?
  bannerPath                      String?
  sliderLink                      String?
  sliderPath                      String?
  status                          Boolean             @default(true)
  luxuaryAmount                   Decimal?
  maxBidLimit                     Decimal?
  maxStartPrice                   Decimal?
  minimumLuxuarySD_forBidder      Decimal?
  minimumLuxuarySD_forSeller      Decimal?
  percentageOfLuxuarySD_forBidder Decimal?
  percentageOfLuxuarySD_forSeller Decimal?
  LuxuaryFeesPercentage           Decimal?            @default(2)
  feesPercentage                  Decimal?            @default(0.5)
  bannerLinkAr                    String?
  bannerPathAr                    String?
  brands                          Brand[]
  customFields                    CustomFields[]
  nonRegisteredUsers              NonRegisteredUser[]
  products                        Product[]
  subCategories                   SubCategory[]
}

model SubCategory {
  id           Int            @id @default(autoincrement())
  categoryId   Int
  createdAt    DateTime       @default(now())
  nameAr       String
  nameEn       String
  imageLink    String?
  imagePath    String?
  customFields CustomFields[]
  products     Product[]
  category     Category       @relation(fields: [categoryId], references: [id])
}

model CustomFields {
  id            Int          @id @default(autoincrement())
  subCategoryId Int?
  categoryId    Int?
  key           String
  type          String
  labelAr       String
  labelEn       String
  resKey        String       @default("")
  category      Category?    @relation(fields: [categoryId], references: [id])
  subCategory   SubCategory? @relation(fields: [subCategoryId], references: [id])
}

model Brand {
  id         Int      @id @default(autoincrement())
  name       String
  categoryId Int
  createdAt  DateTime @default(now())
  category   Category @relation(fields: [categoryId], references: [id])
}

model Product {
  id                  Int             @id @default(autoincrement())
  categoryId          Int
  subCategoryId       Int?
  quantity            Int             @default(1)
  title               String
  model               String?
  usageStatus         UsageStatus?
  description         String?
  color               String?
  brandId             Int?
  cameraType          String?
  cityId              Int?
  countryId           Int?
  landType            String?
  material            String?
  numberOfFloors      Int?
  numberOfRooms       Int?
  operatingSystem     String?
  processor           String?
  ramSize             Int?
  regionOfManufacture String?
  releaseYear         String?
  screenSize          Float?
  totalArea           Float?
  age                 Int?
  carType             String?
  offerAmount         Decimal?        @default(0)
  isOffer             Boolean         @default(false)
  memory              String?
  brand               String?
  isAuctionProduct    Boolean?        @default(true)
  ProductListingPrice Decimal?        @default(0)
  userId              Int?
  amenities           String?
  annualCommunityFee  Decimal?
  approvedBuildUpArea Decimal?
  buyerTransferFee    Decimal?
  comfort             String?
  commercialType      String?
  developer           String?
  doors               String?
  driverAssistance    String?
  emirate             String?
  engineCapacity      String?
  entertainment       String?
  exteriorFeatures    String?
  freehold            String?
  fuelType            String?
  horsepower          String?
  insuredInUae        String?
  interiorColor       String?
  isFurnished         String?
  kilometers          String?
  maintenanceFee      Decimal?
  numberOfBathrooms   Int?
  numberOfCylinders   String?
  occupancyStatus     String?
  propertyReferenceId String?
  readyBy             String?
  regionalSpecs       String?
  residentialType     String?
  seatingCapacity     String?
  sellerTransferFee   Decimal?
  steeringSide        String?
  totalClosingFee     Decimal?
  transmissionType    String?
  trim                String?
  warranty            String?
  zonedFor            String?
  auction             Auction?
  conversations       Conversation[]
  images              Image[]
  listedProducts      ListedProducts?
  notifications       Notification[]
  category            Category        @relation(fields: [categoryId], references: [id])
  city                City?           @relation(fields: [cityId], references: [id])
  country             Country?        @relation(fields: [countryId], references: [id])
  subCategory         SubCategory?    @relation(fields: [subCategoryId], references: [id])
  user                User?           @relation(fields: [userId], references: [id])
  watchLists          WatchList[]
  comments            Comment[]
}

model Image {
  id        Int      @id @default(autoincrement())
  productId Int
  imagePath String
  imageLink String
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  fcmToken  String?
  user      User     @relation(fields: [userId], references: [id])
}

model Auction {
  id                          Int                    @id @default(autoincrement())
  userId                      Int
  productId                   Int                    @unique
  status                      AuctionStatus          @default(PENDING_OWNER_DEPOIST)
  type                        AuctionType?
  durationInDays              Int?
  durationInHours             Int?
  startBidAmount              Decimal?
  isBuyNowAllowed             Boolean                @default(false)
  acceptedAmount              Decimal?
  startDate                   DateTime?
  createdAt                   DateTime               @default(now())
  durationUnit                DurationUnits?
  expiryDate                  DateTime?
  locationId                  Int?
  endDate                     DateTime?
  isItemSendForDelivery       Boolean?               @default(false)
  IsDelivery                  Boolean?               @default(false)
  IsReturnPolicy              Boolean?               @default(false)
  IsWarranty                  Boolean?               @default(false)
  deliveryPolicyDescription   String?
  numOfDaysOfExpecetdDelivery Int?
  returnPolicyDescription     String?
  warrantyPolicyDescription   String?
  DeliveryFees                Decimal?
  deliveryType                DeliveryType?          @default(NOT_SPECIFIED)
  deliveryRequestsStatus      DeliveryRequestsStatus @default(DELIVERY_PENDING)
  isLocked                    Boolean?               @default(false)
  lockedAt                    DateTime?
  lockedByUserId              Int?
  alletreWallet               AlletreWallet[]
  location                    Location?              @relation(fields: [locationId], references: [id])
  product                     Product                @relation(fields: [productId], references: [id])
  user                        User                   @relation(fields: [userId], references: [id])
  auctionComplaints           AuctionComplaints[]
  bids                        Bids[]
  JoinedAuction               JoinedAuction[]
  notifications               Notification[]
  Payment                     Payment[]
  profit                      Profit[]
  Wallet                      Wallet[]
  watchLists                  WatchList[]
}

model ListedProducts {
  id                  Int                  @id @default(autoincrement())
  productId           Int                  @unique
  status              ListedProductsStatus @default(IN_PROGRESS)
  userId              Int
  locationId          Int?
  ProductListingPrice Decimal?             @default(0)
  createdAt           DateTime             @default(now())
  location            Location?            @relation(fields: [locationId], references: [id])
  product             Product              @relation(fields: [productId], references: [id])
  user                User                 @relation(fields: [userId], references: [id])
}

model Purchase {
  id              Int             @id @default(autoincrement())
  productId       Int             @unique
  sellerId        Int
  buyerId         Int
  purchaseDate    DateTime        @default(now())
  productQuantity Int             @default(1)
  productAmount   Decimal
  totalAmount     Decimal
  alletreWallet   AlletreWallet[]
  profit          Profit[]
  Wallet          Wallet[]
}

model WatchList {
  id        Int      @id @default(autoincrement())
  userId    Int
  auctionId Int?
  createdAt DateTime @default(now())
  productId Int?
  auction   Auction? @relation(fields: [auctionId], references: [id])
  product   Product? @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Bids {
  id        Int      @id @default(autoincrement())
  userId    Int
  auctionId Int
  amount    Decimal
  createdAt DateTime @default(now())
  auction   Auction  @relation(fields: [auctionId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Payment {
  id              Int            @id @default(autoincrement())
  userId          Int
  auctionId       Int
  paymentIntentId String?        @unique
  amount          Decimal
  createdAt       DateTime       @default(now())
  status          PaymentStatus  @default(PENDING)
  type            PaymentType?
  isWalletPayment Boolean        @default(false)
  bankStatement   BankStatement?
  auction         Auction        @relation(fields: [auctionId], references: [id])
  user            User           @relation(fields: [userId], references: [id])
}

model BankStatement {
  id            Int      @id @default(autoincrement())
  paymentId     Int?     @unique
  statementPath String
  statementLink String
  createdAt     DateTime @default(now())
  payment       Payment? @relation(fields: [paymentId], references: [id])
}

model JoinedAuction {
  id                          Int                 @id @default(autoincrement())
  userId                      Int
  auctionId                   Int
  createdAt                   DateTime            @default(now())
  status                      JoinedAuctionStatus @default(IN_PROGRESS)
  paymentExpiryDate           DateTime?
  isWarningMessageSent1Hour   Boolean             @default(false)
  isWarningMessageSent24Hours Boolean             @default(false)
  auction                     Auction             @relation(fields: [auctionId], references: [id])
  user                        User                @relation(fields: [userId], references: [id])
}

model Admin {
  id                Int                @id @default(autoincrement())
  fullName          String?
  email             String
  password          String
  imageLink         String?
  imagePath         String?
  createdAt         DateTime           @default(now())
  bugReportMessages BugReportMessage[]
}

model Wallet {
  id                   Int                   @id @default(autoincrement())
  userId               Int
  auctionId            Int?
  purchaseId           Int?
  amount               Decimal
  date                 DateTime              @default(now())
  description          String
  status               WalletStatus
  transactionType      WalletTransactionType
  balance              Decimal
  transactionReference String?               @unique
  auction              Auction?              @relation(fields: [auctionId], references: [id])
  purchase             Purchase?             @relation(fields: [purchaseId], references: [id])
  user                 User                  @relation(fields: [userId], references: [id])
}

model AlletreWallet {
  id                   Int                   @id @default(autoincrement())
  userId               Int
  auctionId            Int?
  purchaseId           Int?
  amount               Decimal
  date                 DateTime              @default(now())
  description          String
  status               WalletStatus
  transactionType      WalletTransactionType
  balance              Decimal
  transactionReference String?               @unique
  auction              Auction?              @relation(fields: [auctionId], references: [id])
  purchase             Purchase?             @relation(fields: [purchaseId], references: [id])
  user                 User                  @relation(fields: [userId], references: [id])
}

model Profit {
  id          Int       @id @default(autoincrement())
  userId      Int
  auctionId   Int?
  purchaseId  Int?
  amount      Decimal
  createdAt   DateTime  @default(now())
  description String
  auction     Auction?  @relation(fields: [auctionId], references: [id])
  purchase    Purchase? @relation(fields: [purchaseId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
}

model AuctionComplaints {
  id            Int                 @id @default(autoincrement())
  userId        Int
  auctionId     Int
  date          DateTime            @default(now())
  message       String
  auctionStatus JoinedAuctionStatus
  problemStatus ProblemStatus       @default(PENDING)
  auction       Auction             @relation(fields: [auctionId], references: [id])
  user          User                @relation(fields: [userId], references: [id])
  images        ComplaintImages[]
}

model ComplaintImages {
  id          Int               @id @default(autoincrement())
  complaintId Int
  imagePath   String
  imageLink   String
  createdAt   DateTime          @default(now())
  complaint   AuctionComplaints @relation(fields: [complaintId], references: [id])
}

model BugReport {
  id              Int                @id @default(autoincrement())
  userId          Int?
  email           String?
  description     String
  status          ProblemStatus      @default(PENDING)
  createdAt       DateTime           @default(now())
  unreadCount     Int                @default(0)
  userUnreadCount Int                @default(0)
  updatedAt       DateTime           @default(now()) @updatedAt
  user            User?              @relation(fields: [userId], references: [id])
  images          BugReportImages[]
  messages        BugReportMessage[]
}

model BugReportImages {
  id          Int       @id @default(autoincrement())
  bugReportId Int
  imagePath   String
  imageLink   String
  createdAt   DateTime  @default(now())
  bugReport   BugReport @relation(fields: [bugReportId], references: [id])
}

model BugReportMessage {
  id          Int       @id @default(autoincrement())
  bugReportId Int
  userId      Int?
  adminId     Int?
  message     String
  createdAt   DateTime  @default(now())
  admin       Admin?    @relation(fields: [adminId], references: [id])
  bugReport   BugReport @relation(fields: [bugReportId], references: [id])
  user        User?     @relation(fields: [userId], references: [id])
}

model Notification {
  id           Int      @id @default(autoincrement())
  userId       Int
  message      String
  createdAt    DateTime @default(now())
  auctionId    Int?
  isRead       Boolean  @default(false)
  updatedAt    DateTime @default(now()) @updatedAt
  imageLink    String?
  productTitle String?
  productId    Int?
  auction      Auction? @relation(fields: [auctionId], references: [id])
  product      Product? @relation(fields: [productId], references: [id])
  user         User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model AppVersion {
  id             Int      @id @default(autoincrement())
  platform       String
  version        String
  isLatest       Boolean  @default(false)
  isMinSupported Boolean  @default(false)
  releaseNotes   String?
  downloadUrl    String?
  createdAt      DateTime @default(now())

  @@index([platform, isLatest])
  @@index([platform, isMinSupported])
}

model Conversation {
  id        Int           @id @default(autoincrement())
  productId Int?
  buyerId   Int
  sellerId  Int
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  buyer     User          @relation("BuyerConversations", fields: [buyerId], references: [id])
  product   Product?      @relation(fields: [productId], references: [id])
  seller    User          @relation("SellerConversations", fields: [sellerId], references: [id])

  @@unique([buyerId, sellerId, productId])
}

model ChatMessage {
  id             Int             @id @default(autoincrement())
  conversationId Int
  senderId       Int
  content        String
  isRead         Boolean         @default(false)
  createdAt      DateTime        @default(now())
  attachmentPath String?
  attachmentUrl  String?
  lat            Float?
  lng            Float?
  type           ChatMessageType @default(TEXT)
  conversation   Conversation    @relation(fields: [conversationId], references: [id])
  sender         User            @relation(fields: [senderId], references: [id])
}

enum ChatMessageType {
  TEXT
  IMAGE
  VIDEO
  DOCUMENT
  LOCATION
}

enum DeliveryRequestsStatus {
  DELIVERY_PENDING
  DELIVERY_SUCCESS
  DELIVERY_IN_PROGRESS
  DELIVERY_FAILED
  DELIVERY_HOLD
}

enum ProblemStatus {
  PENDING
  SOLVED
  IN_PROGRESS
}

enum WalletStatus {
  DEPOSIT
  WITHDRAWAL
}

enum WalletTransactionType {
  By_AUCTION
  BY_DIRECT_SELL
}

enum UsageStatus {
  NEW
  USED
  OPEN_BOX
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  HOLD
  CANCELLED
  BANK_STATEMENT_UPLOADED
}

enum WithdrawalStatus {
  PENDING
  SUCCESS
  FAILED
  HOLD
  CANCELLED
  IN_PROGRESS
}

enum AuctionStatus {
  DRAFTED
  PENDING_OWNER_DEPOIST
  ACTIVE
  IN_SCHEDULED
  ARCHIVED
  SOLD
  EXPIRED
  WAITING_FOR_PAYMENT
  CANCELLED_BEFORE_EXP_DATE
  CANCELLED_AFTER_EXP_DATE
  CANCELLED_BY_ADMIN
}

enum AuctionType {
  ON_TIME
  SCHEDULED
}

enum DurationUnits {
  DAYS
  HOURS
}

enum OAuthType {
  GOOGLE
  FACEBOOK
  APPLE
}

enum JoinedAuctionStatus {
  IN_PROGRESS
  PENDING_PAYMENT
  WAITING_FOR_DELIVERY
  PAYMENT_EXPIRED
  LOST
  COMPLETED
  CANCELLED_BEFORE_EXP_DATE
  CANCELLED_AFTER_EXP_DATE
  CANCELLED_BY_ADMIN
}

enum PaymentType {
  SELLER_DEPOSIT
  BIDDER_DEPOSIT
  AUCTION_PURCHASE
  BUY_NOW_PURCHASE
}

enum DeliveryType {
  NOT_SPECIFIED
  PICKUP
  DELIVERY
}

enum ListedProductsStatus {
  IN_PROGRESS
  OUT_OF_STOCK
  SOLD_OUT
}

model Comment {
  id        Int           @id @default(autoincrement())
  content   String
  productId Int
  userId    Int
  parentId  Int?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  product   Product       @relation(fields: [productId], references: [id])
  user      User          @relation(fields: [userId], references: [id])
  parent    Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[]     @relation("CommentReplies")
  likes     CommentLike[]
}

model CommentLike {
  id        Int      @id @default(autoincrement())
  commentId Int
  userId    Int
  createdAt DateTime @default(now())
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([commentId, userId])
}
